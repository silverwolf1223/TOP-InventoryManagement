<head>
  <link rel="stylesheet" href="/main.css">
</head>
<form action="/edit/<%=item.id%>" method="POST">
    <label for="name">Name: </label>
    <input type="text" name="name" value="<%= item.name %>">
    <label for="stock">Stock: </label>
    <input type="number" name="stock" value="<%= item.stock%>">
    <label for="price">Price: </label>
    <input type="number" step="0.01" name="price" value="<%= item.price %>">
    <label for="type">Instrument Type: </label>
    <input type="text" name="type" value="<%= item.type %>">
    <input type="submit" value="submit">
</form>

<form action="/edit/<%=item.id%>/delete" method="POST">
    <input type="submit" value="Delete Item">
</form>

<a href="/">Return</a>